# BeeBot Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
#
# This file contains SECRETS and BOOTSTRAP config only.
# Operational config (bot emoji, rate limits, WordPress, Eventbrite)
# is managed via /beebot-config in Slack, or by editing
# /app/data/runtime_config.json directly on the host.

# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...)
# From: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# App-Level Token (xapp-...)
# From: api.slack.com → Your App → Basic Information → App-Level Tokens
# Requires connections:write scope
SLACK_APP_TOKEN=xapp-REPLACE-ME

# Channel ID for #new-members (not the name — the ID)
# Right-click the channel in Slack → View channel details → Copy channel ID
NEW_MEMBERS_CHANNEL_ID=C-REPLACE-ME

# Comma-separated Slack User IDs of admins who can run bot admin commands
# (/beebot-sync, /beebot-config, /beebot-logs, /beebot-restart)
# Right-click a user in Slack → View profile → ... → Copy member ID
# Required — leave empty and admin commands are disabled for everyone
ADMIN_SLACK_USER_IDS=U-REPLACE-ME,U-REPLACE-ME2

# ── Anthropic ──────────────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# ── Google Drive ───────────────────────────────────────────────────────────────
# Folder ID from the Drive URL:
# drive.google.com/drive/folders/FOLDER_ID_IS_HERE
GOOGLE_DRIVE_FOLDER_ID=REPLACE-ME

# Path inside container — don't change unless you change the volume mount
GOOGLE_SERVICE_ACCOUNT_JSON=/app/config/service-account.json
