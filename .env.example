# BeeBot Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git

# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...)
# From: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# App-Level Token (xapp-...)
# From: api.slack.com → Your App → Basic Information → App-Level Tokens
# Requires connections:write scope
SLACK_APP_TOKEN=xapp-REPLACE-ME

# Channel ID for #new-members (not the name — the ID)
# Right-click the channel in Slack → View channel details → Copy channel ID
NEW_MEMBERS_CHANNEL_ID=C-REPLACE-ME

# Comma-separated Slack User IDs of admins who can run /beebot-sync
# Right-click a user in Slack → View profile → ... → Copy member ID
# Leave empty to allow all users (not recommended for production)
ADMIN_SLACK_USER_IDS=U-REPLACE-ME,U-REPLACE-ME2

# ── Anthropic ──────────────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Claude model to use (optional — defaults to claude-haiku-4-5)
# CLAUDE_MODEL=claude-haiku-4-5

# ── Bot Appearance ─────────────────────────────────────────────────────────────
# Emoji shown in bot messages (optional — defaults to :robot_face:)
# Use a custom workspace emoji if available, e.g. :hive76:
# BOT_EMOJI=:robot_face:

# ── Google Drive ───────────────────────────────────────────────────────────────
# Folder ID from the Drive URL:
# drive.google.com/drive/folders/FOLDER_ID_IS_HERE
GOOGLE_DRIVE_FOLDER_ID=REPLACE-ME

# Path inside container — don't change unless you change the volume mount
GOOGLE_SERVICE_ACCOUNT_JSON=/app/config/service-account.json

# ── WordPress (optional) ───────────────────────────────────────────────────────
# Internal URL to WordPress (avoids Cloudflare/CDN blocks from the server's own IP)
# Example: http://host.docker.internal:32774
# Leave empty to disable WordPress sync
WORDPRESS_BASE_URL=

# WP REST API category slug for syncing posts (pages use parent=0, no category needed)
WORDPRESS_SYNC_CATEGORY=beebot-slackbot

# Comma-separated WP page slugs to exclude from sync (optional — uses defaults if not set)
# WORDPRESS_SLUG_BLOCKLIST=billing,wiki,home,password-reset,membership-registration,membership-profile,redirect-handler,redirect-handler-local,new-member-signup

# ── Eventbrite (optional) ──────────────────────────────────────────────────────
# Private token: eventbrite.com → Account Settings → Developer Links → API Keys
# Org ID: from your Eventbrite org URL (number at the end)
# Leave empty to disable Eventbrite sync
EVENTBRITE_PRIVATE_TOKEN=REPLACE-ME
EVENTBRITE_ORG_ID=REPLACE-ME

# ── Knowledge Base ─────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_PATH=/app/data/knowledge_base.txt

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Max questions per user per window
RATE_LIMIT_MAX=10
# Window in seconds (3600 = 1 hour)
RATE_LIMIT_WINDOW_SEC=3600
